# R session artifacts
.Rhistory
.RData
.RDataTmp
.Ruserdata
.Rproj.user/
.Renviron

# Quarto build internals (not needed in git)
/.quarto/
_freeze/
_quarto_internal_*.scss

# Ignore rendered files everywhere EXCEPT inside docs/
# (docs/ is what GitHub Pages serves)
**/*.html
**/*.docx
**/*.pptx
**/*.pdf
**/*.quarto_ipynb
*_cache/
*.utf8.md
*.knit.md

# ── Whitelist docs/ so GitHub Pages works ──
!/docs/
!/docs/**

# macOS / Positron noise
.DS_Store
**/.DS_Store
.positai